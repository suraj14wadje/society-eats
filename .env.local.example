# Copy to .env.local and fill in real values. .env.local is gitignored.

# Supabase — get these from: https://app.supabase.com/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY, never prefix NEXT_PUBLIC_.
# Bypasses RLS. Keep out of the client bundle.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# UPI — shown to customers at checkout. Include the app's deep link and a
# URL to a pre-generated QR image (host on Supabase Storage or /public/).
NEXT_PUBLIC_UPI_ID=yourname@upi
NEXT_PUBLIC_UPI_QR_URL=/upi-qr.png

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
