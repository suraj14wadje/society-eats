# Copy to .env.local and fill in real values. .env.local is gitignored.
#
# For LOCAL dev (the default for v1):
#   1. `npx supabase start` — spins up Postgres + Auth + Storage in Docker
#   2. `npx supabase status -o env` — prints API_URL, ANON_KEY, SERVICE_ROLE_KEY
#   3. Paste those values into the three Supabase vars below.
#
# For CLOUD dev (deferred — see SETUP.md Section 2, tracked in #9):
#   replace 127.0.0.1:54321 with https://<project-ref>.supabase.co
#   and use keys from the Supabase dashboard → Settings → API.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# Service role key — SERVER ONLY, never prefix NEXT_PUBLIC_.
# Bypasses RLS. Keep out of the client bundle.
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
